#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/common.sh
source "$ROOT_DIR/lib/common.sh"
# shellcheck source=../lib/detect.sh
source "$ROOT_DIR/lib/detect.sh"
# shellcheck source=../lib/mount_fix.sh
source "$ROOT_DIR/lib/mount_fix.sh"
# shellcheck source=../lib/tree_fix.sh
source "$ROOT_DIR/lib/tree_fix.sh"
# shellcheck source=../lib/report.sh
source "$ROOT_DIR/lib/report.sh"

config_path="$(default_config_path)"
dry_run=""

usage() {
  cat <<USAGE
Usage:
  ntfs-perm-fix [--config <path>] [--dry-run]
  ntfs-perm-fix check <mountpoint>
  ntfs-perm-fix plan <mountpoint>
  ntfs-perm-fix apply <mountpoint>
  ntfs-perm-fix report
USAGE
}

run_check() {
  local mountpoint="$1"
  local mount_info
  local fs
  local driver
  local report_paths

  mount_info="$(collect_checked_mount_info "$mountpoint")"
  fs="$(mount_info_value "$mount_info" "filesystem" || mount_info_value "$mount_info" "fstype" || printf 'unknown\n')"
  driver="$(mount_info_value "$mount_info" "driver" || printf 'unknown\n')"
  report_paths="$(write_report_files "$ROOT_DIR/logs" "check" "$mountpoint" "ok" "$fs" "$driver")"

  printf '%s\n' "$mount_info"
  printf '%s\n' "$report_paths"
}

collect_checked_mount_info() {
  local mountpoint="$1"

  if ! path_exists "$mountpoint"; then
    log_error "path not found: $mountpoint"
    return 1
  fi

  if ! is_mountpoint_path "$mountpoint"; then
    log_error "not a mountpoint: $mountpoint"
    return 1
  fi

  collect_mount_info "$mountpoint"
}

mount_info_value() {
  local mount_info="$1"
  local key="$2"
  local line

  while IFS= read -r line; do
    if [[ "$line" == "$key="* ]]; then
      printf '%s\n' "${line#"$key="}"
      return 0
    fi
  done <<<"$mount_info"

  return 1
}

run_plan() {
  local mountpoint="$1"
  local mount_info
  local source_spec
  local raw_fs
  local fs
  local driver
  local recommended_driver
  local fstab_line
  local report_paths

  mount_info="$(collect_checked_mount_info "$mountpoint")"
  source_spec="$(mount_info_value "$mount_info" "source")"
  raw_fs="$(mount_info_value "$mount_info" "fstype")"
  fs="$(mount_info_value "$mount_info" "filesystem" || printf '%s\n' "$raw_fs")"
  driver="$(mount_info_value "$mount_info" "driver" || printf 'unknown\n')"
  recommended_driver="$(recommend_driver "$raw_fs")"
  fstab_line="$(build_fstab_line "$source_spec" "$mountpoint" "$recommended_driver" "1000" "1000" "0022")"

  report_paths="$(write_report_files "$ROOT_DIR/logs" "plan" "$mountpoint" "warning" "$fs" "$driver")"

  printf '%s\n' "$report_paths"
  printf '建议fstab: %s\n' "$fstab_line"
}

run_report() {
  local latest_report

  latest_report="$(ls -1t "$ROOT_DIR"/logs/report-*.txt 2>/dev/null | head -n 1 || true)"
  if [[ -z "$latest_report" ]]; then
    log_error "no report found in $ROOT_DIR/logs"
    return 1
  fi

  cat "$latest_report"
}

run_apply() {
  local mountpoint="$1"
  local mount_info
  local raw_fs
  local normalized_fs
  local fs
  local driver
  local issue_counts
  local report_paths
  local result_status="success"
  local total_issues="0"
  local apply_mode="apply"

  require_root || return 1

  mount_info="$(collect_checked_mount_info "$mountpoint")"
  raw_fs="$(mount_info_value "$mount_info" "fstype")"
  normalized_fs="$(classify_fs "$raw_fs")"
  fs="$(mount_info_value "$mount_info" "filesystem" || printf '%s\n' "$normalized_fs")"
  driver="$(mount_info_value "$mount_info" "driver" || true)"

  if [[ "$normalized_fs" != "ntfs" && "$raw_fs" != "ntfs3" && "$driver" != "ntfs3" ]]; then
    log_error "NTFS filesystem required for apply: $mountpoint (got: $raw_fs)"
    return 1
  fi

  if [[ "$dry_run" == "true" ]]; then
    apply_mode="dry-run"
  fi

  issue_counts="$(apply_tree_permissions "$mountpoint" "$apply_mode")"
  if total_issues="$(mount_info_value "$issue_counts" "total_issues")"; then
    if [[ "$total_issues" != "0" ]]; then
      result_status="warning"
    fi
  fi

  report_paths="$(write_report_files "$ROOT_DIR/logs" "apply" "$mountpoint" "$result_status" "$fs" "${driver:-unknown}" "result")"
  printf '%s\n' "$report_paths"
  printf '%s\n' "$issue_counts"
}

if [[ "${1:-}" == "check" ]]; then
  shift

  if [[ $# -lt 1 || -z "${1:-}" ]]; then
    log_error "check requires a mountpoint"
    usage
    exit 1
  fi

  mountpoint="$1"
  shift

  if [[ $# -gt 0 ]]; then
    log_error "unexpected argument for check: $1"
    usage
    exit 1
  fi

  run_check "$mountpoint"
  exit $?
fi

if [[ "${1:-}" == "plan" ]]; then
  shift

  if [[ $# -lt 1 || -z "${1:-}" ]]; then
    log_error "plan requires a mountpoint"
    usage
    exit 1
  fi

  mountpoint="$1"
  shift

  if [[ $# -gt 0 ]]; then
    log_error "unexpected argument for plan: $1"
    usage
    exit 1
  fi

  run_plan "$mountpoint"
  exit $?
fi

if [[ "${1:-}" == "report" ]]; then
  shift

  if [[ $# -gt 0 ]]; then
    log_error "report does not accept arguments"
    usage
    exit 1
  fi

  run_report
  exit $?
fi

if [[ "${1:-}" == "apply" ]]; then
  shift

  mountpoint=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run="true"
        shift
        ;;
      *)
        if [[ -z "${mountpoint:-}" ]]; then
          mountpoint="$1"
          shift
        else
          log_error "unexpected argument for apply: $1"
          usage
          exit 1
        fi
        ;;
    esac
  done

  if [[ -z "${mountpoint:-}" ]]; then
    log_error "apply requires a mountpoint"
    usage
    exit 1
  fi

  run_apply "$mountpoint"
  exit $?
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)
      if [[ $# -lt 2 || -z "${2:-}" ]]; then
        log_error "--config requires a value"
        usage
        exit 1
      fi
      config_path="$2"
      shift 2
      ;;
    --dry-run)
      dry_run="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      log_error "unknown argument: $1"
      usage
      exit 1
      ;;
  esac
done

log_error "no command specified"
usage
exit 1

log_info "config: $config_path"
if [[ "$dry_run" == "true" ]]; then
  log_warn "running in dry-run mode"
fi

echo "ntfs-perm-fix scaffold is ready"
